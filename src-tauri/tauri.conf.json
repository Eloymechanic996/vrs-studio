{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VRS Studio",
  "version": "1.0.0",
  "identifier": "app.vrs-studio.desktop",
  "build": {
    "frontendDist": "../desktop-shell",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "VRS Studio",
        "label": "main",
        "url": "https://vrs-studio-web.vercel.app",
        "width": 1320,
        "height": 860,
        "minWidth": 920,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Control de competicion - karting y motorsport",
    "longDescription": "VRS Studio - registra sesiones, vueltas, sectores, eventos y setup. Analiza pace, stints y compara sesiones. Empaquetado desde la PWA web.",
    "publisher": "VRS Studio",
    "copyright": "",
    "homepage": "https://vrs-studio-web.vercel.app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "es-ES"
      }
    }
  }
}
